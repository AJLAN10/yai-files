---
import HeritageLayout from '../layouts/HeritageLayout.astro';
---
<HeritageLayout
  title="Privacy — Yemen Architecture Initiative"
  description="Privacy approach of the Yemen Architecture Initiative."
  eyebrow="Privacy"
  eyebrowAr="الخصوصية"
  accent="#64748B"
  heading="Privacy"
  headingAr="الخصوصية"
>
  <p class="lede en-only">The platform uses privacy-first, cookie-free analytics and collects no personal data. A full privacy statement will be published here.</p>
  <p class="lede ar-only ar-text">تستخدم المنصة تحليلات تحترم الخصوصية بلا ملفات تعريف ارتباط، ولا تجمع أي بيانات شخصية. سيُنشَر بيان خصوصية كامل هنا.</p>
  <p class="cross-ref"><a href="/"><span class="en-only">Back to home →</span><span class="ar-only ar-text">العودة للرئيسية ←</span></a></p>
  <style>
    .lede { font-size: 1.05rem; line-height: 1.8; color: rgba(255,255,255,0.75); max-width: 52ch; }
    .cross-ref { margin-top: 2rem; } .cross-ref a { color: var(--accent); }
  </style>
</HeritageLayout>

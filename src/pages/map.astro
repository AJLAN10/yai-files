      <text x="372" y="102" style="font-family:'DM Sans',system-ui;font-size:8px;fill:rgba(245,158,11,0.7);pointer-events:none">Sheba ★</text>

      <!-- Socotra connector line -->
      <line x1="500" y1="208" x2="580" y2="315" stroke="rgba(167,139,250,0.15)" stroke-width="1" stroke-dasharray="4,6"/>
    </svg>

    <!-- Map legend -->
    <div class="map-legend" aria-label="Map legend" role="list">
      <div class="ml-item" role="listitem"><div class="ml-dot" style="background:#4ADE80"></div>Highland</div>
      <div class="ml-item" role="listitem"><div class="ml-dot" style="background:#FBBF24"></div>Desert</div>
      <div class="ml-item" role="listitem"><div class="ml-dot" style="background:#60A5FA"></div>Coastal</div>
      <div class="ml-item" role="listitem"><div class="ml-dot" style="background:#F59E0B"></div>Ancient</div>
      <div class="ml-item" role="listitem"><div class="ml-dot" style="background:#A78BFA"></div>Island</div>
      <div class="ml-item" role="listitem"><div class="ml-dot" style="background:#F59E0B;clip-path:polygon(50% 0%,61% 35%,98% 35%,68% 57%,79% 91%,50% 70%,21% 91%,32% 57%,2% 35%,39% 35%)"></div>Sheba Kingdom</div>
    </div>

    <!-- Tooltip -->
    <div class="map-tooltip" id="mapTooltip" role="tooltip" aria-live="polite"></div>

    <!-- Detail panel -->
    <div class="detail-panel" id="detailPanel" role="dialog" aria-label="Character detail" aria-modal="false">
      <div class="dp-close">
        <span class="dp-char-num" id="dpNum">—</span>
        <button class="dp-close-btn" id="closePanelBtn" aria-label="Close character detail">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>

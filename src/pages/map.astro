---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

/* Single source of truth: the character data now lives in the
   `characters` collection. We shape it into the flat record the
   client script expects and inject it as JSON (the SVG marker
   positions remain authored in the markup below). */
const order = [
  'sheba', 'sanaa-capital', 'hadramawt', 'sadah', 'hudaydah', 'socotra',
  'aden', 'hajjah', 'taizz', 'marib', 'ibb', 'lahij', 'shabwah',
];
const characters = await getCollection('characters');
const charData = characters
  .map((e) => ({
    id: e.id,
    num: e.data.num,
    name: e.data.name,
    tag: e.data.tag,
    type: e.data.type,
    gov: e.data.governorate,
    material: e.data.material_list.join(' · '),
    period: e.data.era,
    desc: e.data.description,
    elements: e.data.elements,
    trad: e.data.traditional,
    trans: e.data.transitional,
    cont: e.data.contemporary,
  }))
  .sort((a, b) => {
    const ia = order.indexOf(a.id), ib = order.indexOf(b.id);
    return (ia === -1 ? 99 : ia) - (ib === -1 ? 99 : ib);
  });
---
<BaseLayout
  title="Architectural Characters Map — Yemen Architecture Initiative"
  description="Interactive map of Yemen's 23 architectural characters across 22 governorates and the Sheba Kingdom — explore by region, material, and typology."
>
<Fragment slot="head">
<link rel="canonical" href="https://yai.org/map">
</Fragment>

<!-- NAV -->
<nav class="nav" role="navigation" aria-label="Map navigation">
  <a href="/" class="nav-back" aria-label="Back to home">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    YAI
  </a>
  <span class="nav-title">Architecture <span>Map</span></span>
  <div class="search-wrap">
    <span class="search-icon" aria-hidden="true">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    </span>
    <input class="search-input" id="searchInput" type="search" placeholder="Search characters…" aria-label="Search architectural characters" autocomplete="off">
  </div>
  <span class="nav-count" id="countLabel">23 characters</span>
</nav>

<!-- LAYOUT -->
<div class="layout">

  <!-- SIDEBAR -->
  <aside class="sidebar" role="complementary" aria-label="Character list">
    <div class="filter-bar" role="group" aria-label="Filter by type">
      <button class="filter-btn active" data-f="all" aria-pressed="true">All</button>
      <button class="filter-btn" data-f="highland" aria-pressed="false">Highland</button>
      <button class="filter-btn" data-f="desert" aria-pressed="false">Desert</button>
      <button class="filter-btn" data-f="coastal" aria-pressed="false">Coastal</button>
      <button class="filter-btn" data-f="ancient" aria-pressed="false">Ancient</button>
      <button class="filter-btn" data-f="island" aria-pressed="false">Island</button>
    </div>
    <div class="chars-list" id="charsList" role="list" aria-label="Architectural characters">

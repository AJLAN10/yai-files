<script id="char-data" type="application/json" is:inline set:html={JSON.stringify(charData)}></script>
<script is:inline>
'use strict';

/* ── Character data (from the `characters` collection) ── */
const CHARACTERS = JSON.parse(document.getElementById('char-data').textContent);

/* ── Build sidebar ── */
const list = document.getElementById('charsList');
CHARACTERS.forEach(c => {
  const item = document.createElement('div');
  item.className = `char-item${c.id==='sheba'?' sheba-item':''}`;
  item.dataset.id = c.id;
  item.dataset.type = c.type;
  item.setAttribute('role','listitem');
  item.setAttribute('tabindex','0');
  item.setAttribute('aria-label', c.name);
  item.innerHTML = `
    <span class="char-type-dot"></span>
    <div class="char-info">
      <div class="char-num">${c.num}</div>
      <div class="char-name">${c.name}</div>
      <div class="char-tag">${c.tag}</div>
    </div>
    <svg class="char-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
  `;
  item.addEventListener('click', () => openChar(c.id));
  item.addEventListener('keydown', e => { if(e.key==='Enter') openChar(c.id); });
  list.appendChild(item);
});

/* ── Open character ── */
const detailPanel = document.getElementById('detailPanel');
const dpBody = document.getElementById('dpBody');
const dpNum  = document.getElementById('dpNum');
let activeId = null;

function openChar(id) {
  const c = CHARACTERS.find(x => x.id === id);
  if (!c) return;
  activeId = id;

  // Sidebar highlight
  document.querySelectorAll('.char-item').forEach(i => i.classList.remove('active'));
  const si = document.querySelector(`.char-item[data-id="${id}"]`);
  if (si) { si.classList.add('active'); si.scrollIntoView({block:'nearest',behavior:'smooth'}); }

  // Map marker highlight
  document.querySelectorAll('.city-marker').forEach(m => m.classList.remove('active'));
  const mm = document.querySelector(`.city-marker[data-id="${id}"]`);
  if (mm) mm.classList.add('active');

  dpNum.textContent = `Character ${c.num}`;
  dpBody.innerHTML = `
    <div class="dp-type-badge" data-t="${c.type}"><span>${c.type.charAt(0).toUpperCase()+c.type.slice(1)}</span></div>
    <div class="dp-name">${c.name}</div>
    <div class="dp-gov">${c.gov}</div>
    <div class="dp-stats">
      <div class="dp-stat"><span class="dp-stat-val">${c.material.split('·')[0].trim()}</span><span class="dp-stat-lbl">Primary material</span></div>
      <div class="dp-stat"><span class="dp-stat-val">${c.period}</span><span class="dp-stat-lbl">Period</span></div>
    </div>
    <div class="dp-section">
      <div class="dp-section-title">Architectural character</div>
      <p class="dp-text">${c.desc}</p>
    </div>
    <div class="dp-section">
      <div class="dp-section-title">Signature elements</div>
      <div class="dp-elements">${c.elements.map(e=>`<span class="dp-el">${e}</span>`).join('')}</div>
    </div>
    <div class="dp-section">
      <div class="dp-section-title">Design typologies</div>
      <div class="dp-typologies">
        <div class="dp-typo trad"><div class="dp-typo-label">Traditional</div><div class="dp-typo-desc">${c.trad}</div></div>
        <div class="dp-typo trans"><div class="dp-typo-label">Transitional</div><div class="dp-typo-desc">${c.trans}</div></div>
        <div class="dp-typo cont"><div class="dp-typo-label">Contemporary</div><div class="dp-typo-desc">${c.cont}</div></div>
      </div>
    </div>
    <div class="dp-actions">
      <button class="dp-btn-primary" onclick="window.location='/details/${c.id}'">Full character card →</button>
      <button class="dp-btn-secondary" onclick="window.location='/code'">YBC</button>
    </div>
  `;
  detailPanel.classList.add('open');
  detailPanel.setAttribute('aria-modal','true');
}

document.getElementById('closePanelBtn').addEventListener('click', () => {
  detailPanel.classList.remove('open');
  detailPanel.removeAttribute('aria-modal');
  document.querySelectorAll('.char-item,.city-marker').forEach(e => e.classList.remove('active'));
  activeId = null;
});

/* ── Map markers ── */
document.querySelectorAll('.city-marker,.sheba-star').forEach(m => {
  m.addEventListener('click', () => openChar(m.dataset.id));
  m.addEventListener('keydown', e => { if(e.key==='Enter') openChar(m.dataset.id); });
});

/* ── Tooltip ── */
const tooltip = document.getElementById('mapTooltip');
document.querySelectorAll('.city-marker').forEach(m => {
  m.addEventListener('mouseenter', e => {
    const c = CHARACTERS.find(x=>x.id===m.dataset.id);
    if (!c) return;
    tooltip.textContent = `${c.name} — ${c.tag}`;
    tooltip.classList.add('visible');
  });
  m.addEventListener('mousemove', e => {
    const rect = e.currentTarget.closest('.map-area').getBoundingClientRect();
    tooltip.style.left = (e.clientX - rect.left + 12) + 'px';
    tooltip.style.top  = (e.clientY - rect.top  - 8) + 'px';
  });
  m.addEventListener('mouseleave', () => tooltip.classList.remove('visible'));
});

/* ── Filter ── */
let activeFilter = 'all';
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    activeFilter = btn.dataset.f;
    document.querySelectorAll('.filter-btn').forEach(b => { b.classList.remove('active'); b.setAttribute('aria-pressed','false'); });
    btn.classList.add('active'); btn.setAttribute('aria-pressed','true');
    filterChars();
  });
});

function filterChars() {
  let visible = 0;
  document.querySelectorAll('.char-item').forEach(item => {
    const show = activeFilter==='all' || item.dataset.type===activeFilter;
    item.classList.toggle('hidden', !show);
    if (show) visible++;
  });
  document.querySelectorAll('.city-marker').forEach(m => {
    const show = activeFilter==='all' || m.dataset.type===activeFilter;
    m.style.opacity = show ? '1' : '0.15';
    m.style.pointerEvents = show ? '' : 'none';
  });
  const sheba = document.querySelector('.sheba-star');
  if (sheba) { const show = activeFilter==='all'||activeFilter==='ancient'; sheba.style.opacity=show?'1':'0.15'; }
  document.getElementById('countLabel').textContent = `${visible} character${visible!==1?'s':''}`;
}

/* ── Search ── */
document.getElementById('searchInput').addEventListener('input', function() {
  const q = this.value.toLowerCase();
  let visible = 0;
  document.querySelectorAll('.char-item').forEach(item => {
    const c = CHARACTERS.find(x => x.id===item.dataset.id);
    if (!c) return;
    const match = !q || c.name.toLowerCase().includes(q) || c.tag.toLowerCase().includes(q) || c.gov.toLowerCase().includes(q);
    item.classList.toggle('hidden', !match);
    if (match) visible++;
  });
  document.getElementById('countLabel').textContent = `${visible} result${visible!==1?'s':''}`;
});

/* ── Keyboard: Escape closes panel ── */
document.addEventListener('keydown', e => { if(e.key==='Escape') document.getElementById('closePanelBtn').click(); });
</script>
</BaseLayout>

<style>
:root{
  --ink:#0F172A;--stone:#334155;--muted:#64748B;--sky:#0369A1;
  --parchment:#F8FAFC;--sand:#C4A77D;--gold:#B45309;
  --surface:#FFFFFF;--border:#E2E8F0;
  --c-h:#15803D;--c-d:#B45309;--c-c:#0369A1;--c-a:#7C3AED;--c-i:#0891B2;
  --nav-h:60px;
  --f-display:'Cormorant Garamond',serif;
  --f-body:'DM Sans',system-ui,sans-serif;
  --f-mono:'Fira Code',monospace;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:15px;height:100%}
body{font-family:var(--f-body);background:var(--ink);color:#fff;height:100%;overflow:hidden;display:flex;flex-direction:column}
:focus-visible{outline:3px solid var(--sky);outline-offset:2px;border-radius:2px}
button{border:none;cursor:pointer;font:inherit}

/* ── NAV ── */
.nav{height:var(--nav-h);background:rgba(15,23,42,0.96);backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,0.07);display:flex;align-items:center;padding:0 1.25rem;gap:1rem;flex-shrink:0;z-index:100}
.nav-back{display:flex;align-items:center;gap:0.5rem;font-size:0.78rem;color:rgba(255,255,255,0.45);transition:color 0.15s;cursor:pointer}
.nav-back:hover{color:rgba(255,255,255,0.8)}
.nav-title{font-family:var(--f-display);font-size:1.1rem;font-weight:500;color:#fff;margin-right:auto}
.nav-title span{color:var(--sand)}
.search-wrap{position:relative;flex:1;max-width:280px}
.search-input{width:100%;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:6px;color:#fff;font-family:var(--f-body);font-size:0.82rem;padding:0.5rem 0.75rem 0.5rem 2.25rem;outline:none;transition:border-color 0.15s}
.search-input::placeholder{color:rgba(255,255,255,0.3)}
.search-input:focus{border-color:rgba(255,255,255,0.3)}
.search-icon{position:absolute;left:0.625rem;top:50%;transform:translateY(-50%);color:rgba(255,255,255,0.3);pointer-events:none}
.nav-count{font-family:var(--f-mono);font-size:0.72rem;color:rgba(255,255,255,0.25);white-space:nowrap}

/* ── LAYOUT: sidebar + map ── */
.layout{display:grid;grid-template-columns:320px 1fr;flex:1;overflow:hidden}

/* ── SIDEBAR ── */
.sidebar{background:#0B1120;border-right:1px solid rgba(255,255,255,0.06);display:flex;flex-direction:column;overflow:hidden}
.filter-bar{padding:0.875rem 1rem;border-bottom:1px solid rgba(255,255,255,0.06);display:flex;flex-wrap:wrap;gap:0.375rem}
.filter-btn{font-size:0.68rem;font-weight:500;letter-spacing:0.05em;text-transform:uppercase;padding:0.3rem 0.7rem;border-radius:20px;border:1px solid rgba(255,255,255,0.1);background:transparent;color:rgba(255,255,255,0.45);transition:all 0.15s;cursor:pointer;white-space:nowrap}
.filter-btn:hover{border-color:rgba(255,255,255,0.3);color:rgba(255,255,255,0.7)}
.filter-btn.active{color:#fff;border-color:transparent}
.filter-btn[data-f="all"].active{background:rgba(255,255,255,0.12)}
.filter-btn[data-f="highland"].active{background:var(--c-h);border-color:var(--c-h)}
.filter-btn[data-f="desert"].active{background:var(--c-d);border-color:var(--c-d)}
.filter-btn[data-f="coastal"].active{background:var(--c-c);border-color:var(--c-c)}

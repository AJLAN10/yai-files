---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Yemen Building Code (YBC) — Heritage Module · YAI"
  description="The Yemen Building Code Heritage Module — 8 technical chapters covering mudbrick, fired brick, coral stone, rammed earth, seismic, flood, and post-conflict reconstruction standards."
>
<Fragment slot="head">
<link rel="canonical" href="https://yai.org/code">
</Fragment>

<nav class="nav" role="navigation">
  <a href="/" class="nav-back"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>YAI</a>
  <span class="nav-title">Yemen Building Code</span>
  <span class="nav-badge">YBC · Heritage Module</span>
  <button class="nav-dl-btn" aria-label="Download full Yemen Building Code PDF">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
    Download YBC (PDF)
  </button>
</nav>

<section class="hero" aria-label="YBC Overview">
  <div class="hero-inner">
    <div>
      <div class="hero-badge">
        <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
        Heritage Building Code · Draft 2026
      </div>
      <h1 class="hero-title">Yemen<br>Building <span>Code</span></h1>
      <p class="hero-desc">The YBC Heritage Module sets technical standards for construction, restoration, and reconstruction across Yemen's four primary material traditions — mudbrick, fired brick, coral stone, and rammed earth — plus seismic, flood, and post-conflict protocols. Modelled on Saudi SBC 902, adapted to Yemen's specific geology and conflict context.</p>
      <div class="hero-meta">
        <div class="meta-item"><span class="meta-val">8</span><span class="meta-lbl">Code chapters</span></div>
        <div class="meta-item"><span class="meta-val">4</span><span class="meta-lbl">Material traditions</span></div>
        <div class="meta-item"><span class="meta-val">22</span><span class="meta-lbl">Governorates covered</span></div>
        <div class="meta-item"><span class="meta-val">ALIPH</span><span class="meta-lbl">Protocol aligned</span></div>
      </div>
    </div>
    <div class="hero-saudi">
      <div class="saudi-label">Benchmark — Saudi SBC 902</div>
      <div class="saudi-compare">
        <div class="sc-title">YBC vs SBC 902</div>
        <div class="sc-row"><span>Primary driver</span><span>Post-conflict rescue</span></div>
        <div class="sc-row"><span>Materials</span><span>Libn · coral · zabur</span></div>
        <div class="sc-row"><span>Urgency</span><span>Emergency + preventive</span></div>
        <div class="sc-row"><span>Special chapter</span><span>Conflict damage</span></div>
        <div class="sc-row"><span>Partners</span><span>UNESCO · ALIPH</span></div>
      </div>
    </div>
  </div>
</section>

<div class="scope-bar">
  <div class="scope-inner">
    <span class="scope-label">Scope</span>
    <span class="scope-tag">New construction in heritage zones</span>
    <span class="scope-tag">Heritage restoration</span>
    <span class="scope-tag">Conflict damage reconstruction</span>
    <span class="scope-tag">Material standards</span>
    <span class="scope-tag">Structural performance</span>
    <span class="scope-tag">Fire protection</span>
    <span class="scope-tag">Flood resilience</span>
    <span class="scope-tag">Seismic codes</span>
  </div>
</div>

<div class="main-layout">
  <!-- TOC -->
  <nav class="toc" role="navigation" aria-label="Code chapters navigation">
    <div class="toc-title">Chapters</div>
    <div class="toc-items" id="tocItems"></div>
    <div class="toc-divider"></div>
    <button class="toc-dl-btn">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Full YBC PDF
    </button>
  </nav>

  <!-- CHAPTERS -->
  <div class="chapters" id="chaptersEl" role="list" aria-label="Yemen Building Code chapters"></div>
</div>

<footer class="page-footer">
  Yemen Architecture Initiative · <a href="/">YAI.org</a> · YBC Heritage Module Draft 2026 · Aligned with ALIPH, UNESCO, and Saudi SBC 902
</footer>

<script is:inline>
const CHAPTERS = [
  {code:'YBC-H00',name:'Overview & Legal Framework',subtitle:'Scope, definitions, classification of heritage structures',status:'review',govs:['All 22 governorates','Socotra'],desc:'Establishes the legal basis, definitions, and classification system for Yemen\'s built heritage. Defines four heritage grades (A–D), geographic scope across all 22 governorates, relationship to existing municipal codes, and the authority of the YAI committee for variance applications.',specs:[['Heritage grades','A: National significance · B: Regional · C: Local · D: Contributory'],['Application scope','All structures in classified heritage zones or within 50m of Grade A/B building'],['Authority','YAI Heritage Code Committee — technical review within 45 days'],['Relationship to SBC','YBC-H supersedes SBC 902 for classified Yemeni heritage structures']],trad:'All restoration or reconstruction of Grade A and B structures must comply with YBC-H before any municipal code.',trans:'Grade C and D structures may apply hybrid compliance — YBC-H material standards + municipal structural code.',cont:'New construction in heritage zones must demonstrate character compliance per YAI character card for the governorate.'},
  {code:'YBC-H01',name:'Mudbrick (Libn) Construction',subtitle:'Sun-dried mudbrick — Hadramawt, Marib, Al Jawf, Shabwah',status:'draft',govs:['Hadramawt','Ma\'rib','Al Jawf','Shabwah','Abyan'],desc:'Technical standards for sun-dried mudbrick (libn) construction — the primary material of Shibam, Tarim, and the Wadi Hadramawt tradition. Covers mix ratios, coursing, structural height limits, annual render protocols, and flood-base specifications for wadi-adjacent buildings.',specs:[['Mix ratio (standard)','3 parts clay soil · 1 part sand · 0.5 parts straw binder'],['Brick dimensions','25 × 12 × 8 cm (traditional) · or 30 × 15 × 10 cm (structural)'],['Max height (unrestored)','8 storeys (24m) with approved structural survey — 6 without'],['Annual render','Tayan (mud-lime plaster) applied annually Oct–Nov before rains'],['Flood base','Min. 600mm fired brick or stone plinth at wadi-adjacent sites'],['Wall taper','Batter ratio 1:12 — walls reduce 8cm per floor on outer face']],trad:'Traditional libn — unstabilised sun-dried mud, straw-reinforced, annually rendered. No cement additives.',trans:'Stabilised libn — 5–8% cement or lime admixture permitted for structural upgrade. Must retain render.',cont:'Contemporary libn — precast stabilised mudbrick panels permitted; mix spec and colour must match local earth tone within ΔE < 3.'},
  {code:'YBC-H02',name:'Fired Brick & Gypsum',subtitle:'Sana\'a highland tower house tradition',status:'draft',govs:['Sana\'a Capital','Sana\'a Governorate','Amran','Dhamar','Al Mahwit'],desc:'Standards for fired brick construction with gypsum render — the defining material system of Sana\'a Old City and the highland tower house tradition. Covers brick specification, gypsum banding (diwan friezes), qamaria window fabrication, and minaret construction following Marchand\'s documentation.',specs:[['Brick standard','Local fired clay · 22 × 10 × 6 cm · min 15 N/mm² compressive strength'],['Gypsum render','Diwan frieze bands at every floor level · min 150mm height · white gypsum only'],['Qamaria spec','Alabaster or coloured glass · geometric or floral pattern · YAI catalogue Appendix Q'],['Mortar','Gypsum-lime mortar (1:1) for heritage · Portland cement strictly prohibited on exterior'],['Window ratio','30–40% of facade area maximum · small openings north face · qamaria south/east'],['Minaret coursing','Per Marchand (2001) — gypsum-bonded brick courses 55–65mm · tapered 1:20']],trad:'Traditional Sana\'a — local fired brick, white gypsum diwan bands, stained-glass qamaria fanlights, no modern finishes.',trans:'Transitional — fired brick structure with cement core permitted if exterior face is traditional brick and gypsum render.',cont:'Contemporary highland — brick or concrete structure with fired brick cladding minimum 90mm + gypsum render on all street-facing facades.'},
  {code:'YBC-H03',name:'Coral Stone & Timber',subtitle:'Tihama coastal and Red Sea port tradition',status:'draft',govs:['Al Hudaydah','Aden','Lahij','Abyan'],desc:'Standards for coral stone (marjan) construction on the Red Sea and Gulf of Aden coasts — covering Zabid, Hudaydah port buildings, and Aden\'s Crater district. Includes rawshan carved timber screen specification, courtyard haush typology, and moisture management in the high-humidity coastal environment.',specs:[['Coral grade','Only Grade 2 fossil coral (not live) — sourced from licensed suppliers only'],['Wall thickness','Min 400mm for structural walls · 250mm for internal partitions'],['Mortar','Lime-sand mortar (1:3) — Portland cement prohibited; causes salt crystallisation'],['Rawshan screen','Carved timber · min teak or equivalent hardwood · max projection 600mm from facade'],['Ventilation','Mandatory cross-ventilation through courtyard — minimum 6m² courtyard for residential'],['Damp-proof','30mm lime render base coat at ground floor · no impermeable DPC permitted']],trad:'Traditional Tihama — fossil coral block, lime mortar, carved timber rawshan, open courtyard haush, no cement.',trans:'Transitional — coral block structure with lime mortar; modern plumbing and electrical within wall chases; traditional facade.',cont:'Contemporary Tihama — coral stone cladding (100mm minimum) on concrete frame; rawshan motif as perforated panel; courtyard maintained.'},
  {code:'YBC-H04',name:'Rammed Earth (Zabur)',subtitle:'Northern highland tradition — Sa\'dah and Hajjah',status:'draft',govs:['Sa\'dah','Hajjah','Amran'],desc:'Technical standards for the zabur rammed-earth tradition of northern Yemen — the most endangered construction knowledge in YAI\'s documentation. Covers compaction standards, course heights, shuttering systems, base isolation, and the critical seismic performance requirements for the tectonically active northern highlands.',specs:[['Course height','Traditional: 300–350mm per lift · Modern stabilised: 250mm per lift'],['Compaction','Manual tamping: 15–20 blows per 300mm layer · Pneumatic: equivalent energy'],['Stabilisation','Optional: 3–5% Portland cement or 8% lime · traditional zabur uses no admixture'],['Base','Min 300mm fired brick or stone course above grade · critical for moisture'],['Wall thickness','Min 600mm for structural walls in seismic zone · 450mm for non-structural'],['Seismic zone','Sa\'dah — Zone 3 (high) · ring beam required at eave level per YBC-H05']],trad:'Pure zabur — natural clay-gravel soil, no stabiliser, manual compaction, earthen render, no Portland cement.',trans:'Stabilised zabur — lime-stabilised earth (8% lime), retained course pattern and earth colour, modern base isolation.',cont:'Contemporary northern — rammed earth block system (CSEB) with matching soil colour; traditional coursing pattern maintained.'},
  {code:'YBC-H05',name:'Seismic Standards',subtitle:'Highland tower house seismic performance and retrofit',status:'review',govs:['Sana\'a Capital','Sa\'dah','Hajjah','Dhamar','Ibb','Ta\'izz'],desc:'Seismic performance requirements for Yemen\'s highland heritage structures — addressing the specific vulnerability of multi-storey mudbrick and fired brick tower houses to earthquake damage. Covers in-situ assessment, graded intervention levels, reversible retrofit techniques, and post-earthquake rapid assessment protocol.',specs:[['Seismic zones','Zone 1 (low): Hadramawt · Zone 2 (moderate): Sana\'a · Zone 3 (high): Sa\'dah, Hajjah'],['Assessment trigger','Any structure >4 storeys or Grade A/B · mandatory seismic survey before restoration'],['Retrofit principle','Reversible intervention only — no injection grouting of historic fabric without approval'],['Ring beam','Timber ring beam at eave level for unreinforced masonry >3 storeys — traditional form'],['Emergency rating','5-level NZSEE-adapted rapid assessment for post-earthquake triage'],['No-go zone','Portland cement injection into historic rubble masonry walls — strictly prohibited']],trad:'Traditional seismic mitigation — timber lacing courses in Sana\'a brick walls every 3–4 courses (pre-modern aseismic system).',trans:'Graded seismic retrofit — external tie rods, timber ring beams, reversible connections only.',cont:'New-build seismic — reinforced concrete frame with traditional cladding; frame must not be visible from street level.'},
  {code:'YBC-H06',name:'Flood Resilience',subtitle:'Wadi-adjacent and coastal heritage structures',status:'draft',govs:['Hadramawt','Ma\'rib','Al Jawf','Al Hudaydah','Aden'],desc:'Flood resilience standards for Yemen\'s wadi-adjacent heritage cities — most critically Shibam in Wadi Hadramawt, which sits on a raised alluvial platform that has protected it for 1,600 years. Covers platform integrity, drainage maintenance, flood-door specifications, and post-flood emergency assessment protocol.',specs:[['Platform requirement','Wadi-adjacent structures must verify platform elevation above 100-year flood level'],['Base course','Min 600mm fired brick, stone, or coral plinth — libn not permitted below flood line'],['Drainage','All roof water must discharge to internal cisterns (birka) or sealed drains — not wadi'],['Flood doors','Ground floor entrances: hardwood min 50mm, sealed threshold, max 800mm above platform'],['Post-flood assessment','72-hour assessment mandatory after any wadi flood event exceeding platform level'],['Shibam special','Shibam platform — quarterly inspection by licensed structural engineer · YAI register']],trad:'Traditional flood management — raised platform, ground-floor storage only, cistern collection, sealed thresholds.',trans:'Platform reinforcement — lime-grouted rubble masonry platform stabilisation, drainage channels.',cont:'New wadi-adjacent — raised platform mandatory, sealed first floor, flood-resistant libn or stabilised earth above 600mm brick base.'},
  {code:'YBC-H07',name:'Post-Conflict Reconstruction',subtitle:'Damage classification and authenticity standards',status:'draft',govs:['All 22 governorates','Priority: Sana\'a · Ta\'izz · Sa\'dah · Hudaydah'],desc:'A Yemen-specific chapter with no direct Saudi equivalent — addressing the reconstruction of heritage structures damaged by armed conflict. Establishes a 5-grade conflict damage classification (CDC-1 to CDC-5), authenticity requirements for reconstruction, documentation standards before intervention, and the role of evidence-based design where original fabric is lost.',specs:[['CDC scale','CDC-1: Minor · CDC-2: Moderate · CDC-3: Severe · CDC-4: Partial collapse · CDC-5: Total loss'],['Authenticity rule','Original materials must be matched within 10% of original specification by mass'],['Documentation','Photogrammetric survey required before any intervention on CDC-3 or above'],['Reversibility','All interventions must be reversible — no material shall be introduced that damages original'],['Evidence design','CDC-5 sites: reconstruction based on pre-conflict photographs, oral testimony, CEFAS records'],['ALIPH alignment','All CDC-4 and CDC-5 reconstructions require ALIPH protocol review before commencement']],trad:'Traditional reconstruction — material replacement like-for-like, craftsman-led, community knowledge documented.',trans:'Evidence-based reconstruction — combining photographic evidence, 3D scan data, and local mason knowledge.',cont:'Contemporary reconstruction — traditional material base with modern services infrastructure concealed within walls.'},
];

/* Build TOC */
const tocEl = document.getElementById('tocItems');
const chaptersEl = document.getElementById('chaptersEl');

CHAPTERS.forEach((ch,i) => {
  // TOC item
  const ti = document.createElement('button');
  ti.className = 'toc-item';
  ti.dataset.i = i;
  ti.setAttribute('aria-label', ch.name);
  ti.innerHTML = `<span class="toc-code">${ch.code}</span><span>${ch.name}</span>`;
  ti.addEventListener('click', () => { expandChapter(i); ti.scrollIntoView({block:'nearest'}); });
  tocEl.appendChild(ti);

  // Chapter accordion
  const statusClass = {draft:'st-draft',review:'st-review',active:'st-active'}[ch.status]||'st-draft';
  const statusLabel = {draft:'Draft',review:'Under review',active:'Active'}[ch.status]||'Draft';

  const chEl = document.createElement('div');
  chEl.className = 'chapter';
  chEl.dataset.i = i;
  chEl.setAttribute('role','listitem');
  chEl.innerHTML = `
    <div class="chapter-header" tabindex="0" role="button" aria-expanded="false" aria-controls="ch-body-${i}">
      <span class="ch-code">${ch.code}</span>
      <div class="ch-info">
        <span class="ch-name">${ch.name}</span>
        <span class="ch-subtitle">${ch.subtitle}</span>
      </div>
      <span class="ch-status ${statusClass}">${statusLabel}</span>
      <svg class="ch-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
    </div>
    <div class="chapter-body" id="ch-body-${i}" aria-hidden="true">
      <div class="cb-govs">${ch.govs.map(g=>`<span class="gov-tag">${g}</span>`).join('')}</div>
      <div class="cb-grid">
        <div>
          <div class="cb-col-title">Purpose & scope</div>
          <p class="cb-desc">${ch.desc}</p>
        </div>
        <div>
          <div class="cb-col-title">Key specifications</div>
          <div class="cb-spec">
            ${ch.specs.map(([k,v])=>`<div class="spec-row"><span class="spec-key">${k}</span><span class="spec-val">${v}</span></div>`).join('')}
          </div>
        </div>
      </div>
      <div class="cb-col-title">Design typology guidance</div>
      <div class="cb-grid" style="margin-top:0.625rem">
        <div><div class="cb-col-title" style="color:#92400E;border-color:rgba(146,64,14,0.15)">Traditional</div><p class="cb-desc">${ch.trad}</p></div>
        <div><div class="cb-col-title" style="color:#1E40AF;border-color:rgba(30,64,175,0.15)">Transitional</div><p class="cb-desc">${ch.trans}</p></div>
      </div>
      <div class="cb-col-title" style="margin-bottom:0.5rem">Contemporary</div>
      <p class="cb-desc" style="margin-bottom:1rem">${ch.cont}</p>
      <div class="cb-actions">
        <button class="cb-dl"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>Download ${ch.code} (PDF)</button>
        <button class="cb-read">Read full chapter →</button>
      </div>
    </div>
  `;
  const header = chEl.querySelector('.chapter-header');
  header.addEventListener('click', () => expandChapter(i));
  header.addEventListener('keydown', e => { if(e.key==='Enter'||e.key===' '){e.preventDefault();expandChapter(i);} });
  chaptersEl.appendChild(chEl);
});

let activeChapter = null;
function expandChapter(i) {
  const chEl = document.querySelector(`.chapter[data-i="${i}"]`);
  const header = chEl.querySelector('.chapter-header');
  const body = chEl.querySelector('.chapter-body');
  const wasExpanded = chEl.classList.contains('expanded');

  // Collapse all
  document.querySelectorAll('.chapter').forEach(c => {
    c.classList.remove('expanded');
    c.querySelector('.chapter-header').setAttribute('aria-expanded','false');
    c.querySelector('.chapter-body').setAttribute('aria-hidden','true');
  });
  document.querySelectorAll('.toc-item').forEach(t => t.classList.remove('active'));

  if (!wasExpanded) {
    chEl.classList.add('expanded');
    header.setAttribute('aria-expanded','true');
    body.setAttribute('aria-hidden','false');
    document.querySelector(`.toc-item[data-i="${i}"]`).classList.add('active');
    chEl.scrollIntoView({behavior:'smooth',block:'nearest'});
  }
}

// Open first chapter by default
expandChapter(0);
</script>
</BaseLayout>

<style>
:root{--ink:#0F172A;--stone:#334155;--muted:#64748B;--sky:#0369A1;--parchment:#F8FAFC;--sand:#C4A77D;--green:#15803D;--surface:#FFFFFF;--border:#E2E8F0;--nav-h:60px;--f-display:'Cormorant Garamond',serif;--f-body:'DM Sans',system-ui,sans-serif;--f-mono:'Fira Code',monospace}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:15px}
body{font-family:var(--f-body);background:var(--parchment);color:var(--ink)}
:focus-visible{outline:3px solid var(--sky);outline-offset:2px;border-radius:2px}
a{color:inherit;text-decoration:none}
button{border:none;cursor:pointer;font:inherit}

/* NAV */
.nav{position:sticky;top:0;height:var(--nav-h);background:rgba(15,23,42,0.97);backdrop-filter:blur(12px);border-bottom:1px solid rgba(255,255,255,0.07);display:flex;align-items:center;padding:0 1.5rem;gap:1rem;z-index:100}
.nav-back{display:flex;align-items:center;gap:0.5rem;font-size:0.78rem;color:rgba(255,255,255,0.4);cursor:pointer;transition:color 0.15s}
.nav-back:hover{color:rgba(255,255,255,0.8)}
.nav-title{font-family:var(--f-display);font-size:1.1rem;color:#fff;margin-right:auto}
.nav-badge{font-family:var(--f-mono);font-size:0.65rem;background:rgba(21,128,61,0.2);color:#4ADE80;border:1px solid rgba(74,222,128,0.2);padding:0.25rem 0.625rem;border-radius:4px}
.nav-dl-btn{background:var(--green);color:#fff;padding:0.5rem 1rem;border-radius:4px;font-size:0.78rem;font-weight:500;min-height:40px;display:flex;align-items:center;gap:0.375rem;cursor:pointer;transition:opacity 0.15s}
.nav-dl-btn:hover{opacity:0.85}

/* HERO */
.hero{background:var(--ink);padding:4rem 1.5rem 3rem;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 20% 50%,rgba(21,128,61,0.08) 0%,transparent 55%);pointer-events:none}
.hero-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr auto;gap:2rem;align-items:end;position:relative;z-index:1}
.hero-badge{display:inline-flex;align-items:center;gap:0.5rem;font-size:0.65rem;letter-spacing:0.18em;text-transform:uppercase;color:#4ADE80;border:1px solid rgba(74,222,128,0.2);padding:0.35rem 0.875rem;border-radius:20px;margin-bottom:1.25rem}
.hero-title{font-family:var(--f-display);font-size:clamp(2.5rem,6vw,5rem);font-weight:400;color:#fff;line-height:0.95;margin-bottom:1rem}
.hero-title span{color:var(--sand)}
.hero-desc{font-size:0.9rem;color:rgba(255,255,255,0.45);line-height:1.7;max-width:52ch;margin-bottom:1.5rem}
.hero-meta{display:flex;gap:1.5rem;flex-wrap:wrap}
.meta-item{display:flex;flex-direction:column;gap:0.2rem}
.meta-val{font-family:var(--f-display);font-size:1.6rem;color:#fff}
.meta-lbl{font-size:0.65rem;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.3)}
.hero-saudi{text-align:right;display:flex;flex-direction:column;gap:0.75rem;align-self:flex-start;padding-top:1rem}
.saudi-label{font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.2)}
.saudi-compare{background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:8px;padding:1rem 1.25rem;max-width:240px}
.sc-title{font-size:0.8rem;color:rgba(255,255,255,0.5);margin-bottom:0.5rem}
.sc-row{display:flex;justify-content:space-between;font-size:0.72rem;padding:0.25rem 0;border-top:1px solid rgba(255,255,255,0.05);color:rgba(255,255,255,0.35)}
.sc-row span:last-child{color:rgba(255,255,255,0.6)}

/* SCOPE BAR */
.scope-bar{background:rgba(21,128,61,0.06);border-top:1px solid rgba(21,128,61,0.1);border-bottom:1px solid rgba(21,128,61,0.1)}
.scope-inner{max-width:1100px;margin:0 auto;padding:1rem 1.5rem;display:flex;flex-wrap:wrap;gap:0.5rem;align-items:center}
.scope-label{font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-right:0.5rem}
.scope-tag{font-size:0.72rem;padding:0.25rem 0.7rem;background:rgba(21,128,61,0.1);color:var(--green);border:1px solid rgba(21,128,61,0.2);border-radius:20px}

/* MAIN LAYOUT */
.main-layout{max-width:1100px;margin:0 auto;padding:2.5rem 1.5rem;display:grid;grid-template-columns:220px 1fr;gap:2.5rem;align-items:start}

/* STICKY TOC */
.toc{position:sticky;top:calc(var(--nav-h) + 1.5rem)}
.toc-title{font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--muted);margin-bottom:0.875rem}
.toc-items{display:flex;flex-direction:column;gap:0.125rem}
.toc-item{display:flex;align-items:center;gap:0.625rem;font-size:0.8rem;color:var(--muted);padding:0.4rem 0.5rem;border-radius:4px;cursor:pointer;transition:all 0.15s;border:none;background:none;text-align:left;width:100%}
.toc-item:hover{background:rgba(0,0,0,0.04);color:var(--stone)}
.toc-item.active{background:rgba(21,128,61,0.08);color:var(--green);font-weight:500}
.toc-code{font-family:var(--f-mono);font-size:0.65rem;color:var(--muted)}
.toc-item.active .toc-code{color:rgba(21,128,61,0.6)}
.toc-divider{height:1px;background:var(--border);margin:0.5rem 0}
.toc-dl-btn{width:100%;background:var(--green);color:#fff;border-radius:4px;padding:0.625rem;font-size:0.78rem;font-weight:500;display:flex;align-items:center;justify-content:center;gap:0.375rem;cursor:pointer;margin-top:1rem;min-height:40px;transition:opacity 0.15s}
.toc-dl-btn:hover{opacity:0.85}

/* CHAPTERS */
.chapters{display:flex;flex-direction:column;gap:1px;background:var(--border);border:1px solid var(--border);border-radius:12px;overflow:hidden}
.chapter{background:var(--surface)}
.chapter-header{padding:1.25rem 1.5rem;display:grid;grid-template-columns:auto 1fr auto auto;align-items:center;gap:1rem;cursor:pointer;transition:background 0.12s}
.chapter-header:hover{background:#F8FAFC}
.chapter.expanded .chapter-header{background:#F8FAFC;border-bottom:1px solid var(--border)}
.ch-code{font-family:var(--f-mono);font-size:0.72rem;color:var(--muted);background:var(--parchment);padding:0.25rem 0.625rem;border-radius:4px;white-space:nowrap}
.chapter.expanded .ch-code{background:rgba(21,128,61,0.08);color:var(--green)}
.ch-info{display:flex;flex-direction:column;gap:0.2rem}
.ch-name{font-family:var(--f-display);font-size:1.2rem;font-weight:500;color:var(--ink)}
.ch-subtitle{font-size:0.78rem;color:var(--muted)}
.ch-status{font-size:0.65rem;font-weight:500;padding:0.2rem 0.6rem;border-radius:20px;white-space:nowrap}
.st-draft{background:#FEF3C7;color:#92400E}
.st-review{background:#DBEAFE;color:#1E40AF}
.st-active{background:#DCFCE7;color:#14532D}
.ch-arrow{color:var(--muted);transition:transform 0.2s;flex-shrink:0}
.chapter.expanded .ch-arrow{transform:rotate(90deg)}

/* Chapter body */
.chapter-body{display:none;padding:1.5rem;border-top:1px solid var(--border)}
.chapter.expanded .chapter-body{display:block}
.cb-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;margin-bottom:1.5rem}
.cb-col-title{font-size:0.65rem;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted);margin-bottom:0.625rem;padding-bottom:0.375rem;border-bottom:1px solid var(--border)}
.cb-desc{font-size:0.85rem;color:var(--stone);line-height:1.7;margin-bottom:1rem}
.cb-spec{display:flex;flex-direction:column;gap:0.375rem}
.spec-row{display:flex;align-items:baseline;gap:0.75rem;font-size:0.8rem;padding:0.375rem 0;border-bottom:1px solid var(--parchment)}
.spec-key{color:var(--muted);min-width:140px;flex-shrink:0;font-size:0.75rem}
.spec-val{font-family:var(--f-mono);color:var(--stone);font-size:0.78rem}
.cb-govs{display:flex;flex-wrap:wrap;gap:0.375rem;margin-bottom:1.25rem}
.gov-tag{font-size:0.72rem;padding:0.2rem 0.6rem;background:rgba(21,128,61,0.06);border:1px solid rgba(21,128,61,0.15);border-radius:20px;color:var(--green)}
.cb-actions{display:flex;gap:0.625rem;padding-top:1rem;border-top:1px solid var(--border)}
.cb-dl{background:var(--green);color:#fff;padding:0.5rem 1.125rem;border-radius:4px;font-size:0.78rem;font-weight:500;min-height:40px;display:flex;align-items:center;gap:0.375rem;cursor:pointer;transition:opacity 0.15s}
.cb-dl:hover{opacity:0.85}
.cb-read{border:1px solid var(--border);color:var(--stone);padding:0.5rem 1.125rem;border-radius:4px;font-size:0.78rem;min-height:40px;display:flex;align-items:center;cursor:pointer;transition:all 0.15s;background:none}
.cb-read:hover{border-color:var(--stone);color:var(--ink)}

/* FOOTER */
.page-footer{background:var(--ink);margin-top:4rem;padding:2rem 1.5rem;color:rgba(255,255,255,0.3);font-size:0.78rem;text-align:center}
.page-footer a{color:var(--sand);cursor:pointer}

@media(max-width:900px){.main-layout{grid-template-columns:1fr}.toc{display:none}.hero-inner{grid-template-columns:1fr}.hero-saudi{display:none}.cb-grid{grid-template-columns:1fr}}

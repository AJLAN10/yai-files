---
import { getCollection } from 'astro:content';
import HeritageLayout from '../../layouts/HeritageLayout.astro';
import { relatedYbc } from '../../lib/related';
import photoCredits from '../../data/photo-credits.json';

export async function getStaticPaths() {
  const characters = await getCollection('characters');
  return characters.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const c = entry.data;

/* Intelligent cross-link: YBC chapters that govern this character. */
const ybcChapters = await getCollection('ybcChapters');
const related = relatedYbc(c, ybcChapters);

const PENDING = '(الترجمة العربية قيد الإعداد)';
const registers = [
  { key: 'Traditional', key_ar: 'تقليدي', body: c.traditional, body_ar: c.traditional_ar },
  { key: 'Transitional', key_ar: 'انتقالي', body: c.transitional, body_ar: c.transitional_ar },
  { key: 'Contemporary', key_ar: 'معاصر', body: c.contemporary, body_ar: c.contemporary_ar },
];
const riskAr: Record<string, string> = { low: 'منخفض', moderate: 'متوسط', high: 'عالٍ', severe: 'شديد' };
const photo = (photoCredits as Record<string, { src: string; credit: string; license: string; source: string }>)[entry.id];
---
<HeritageLayout
  title={`${c.name} — Architectural Character · YAI`}
  description={c.description}
  eyebrow="Building Character · All Governorates"
  eyebrowAr="الطابع المعماري · كل المحافظات"
  accent="#FBBF24"
  heading={c.name}
  headingAr={c.name_ar}
  image={photo?.src}
  imageCredit={photo?.credit}
  imageLicense={photo?.license}
  imageSource={photo?.source}
  meta={[
    { label: 'No.', label_ar: 'رقم', value: c.num },
    { label: 'Governorate', label_ar: 'المحافظة', value: c.governorate_ar ?? c.governorate },
    { label: 'Era', label_ar: 'الحقبة', value: c.era_ar ?? c.era },
    { label: 'Risk level', label_ar: 'مستوى الخطر', value: riskAr[c.risk_level] ?? c.risk_level },
  ]}
>
  <p class="lede">
    <span class="en-only">{c.description}</span>
    <span class="ar-only ar-text">{c.description_ar ?? PENDING}</span>
  </p>

  <h2 class="section-title"><span class="en-only">Materials</span><span class="ar-only ar-text">المواد</span></h2>
  <ul class="elements en-only">
    {c.material_list.map((m) => <li class="element material">{m}</li>)}
  </ul>
  <ul class="elements ar-only">
    {(c.material_list_ar ?? c.material_list).map((m) => <li class="element material ar-text">{m}</li>)}
  </ul>

  <h2 class="section-title"><span class="en-only">Defining elements</span><span class="ar-only ar-text">العناصر المميزة</span></h2>
  <ul class="elements en-only">
    {c.elements.map((el) => <li class="element">{el}</li>)}
  </ul>
  <ul class="elements ar-only">
    {(c.elements_ar ?? c.elements).map((el) => <li class="element ar-text">{el}</li>)}
  </ul>

  <h2 class="section-title"><span class="en-only">Three registers</span><span class="ar-only ar-text">السجلات الثلاثة</span></h2>
  <div class="registers">
    {registers.map((r) => (
      <div class="register">
        <span class="register-key"><span class="en-only">{r.key}</span><span class="ar-only ar-text">{r.key_ar}</span></span>
        <p class="register-body">
          <span class="en-only">{r.body}</span>
          <span class="ar-only ar-text">{r.body_ar ?? PENDING}</span>
        </p>
      </div>
    ))}
  </div>

  {c.diagram && (
    <>
      <h2 class="section-title">
        <span class="en-only">Construction logic</span>
        <span class="ar-only ar-text">منطق البناء</span>
      </h2>
      <figure class="ch-diagram">
        <img src={c.diagram} alt={c.diagram_caption ?? `${c.name} construction diagram`} loading="lazy" />
        {c.diagram_caption && (
          <figcaption><span class="en-only">{c.diagram_caption}</span><span class="ar-only ar-text">{c.diagram_caption_ar ?? c.diagram_caption}</span></figcaption>
        )}
      </figure>
    </>
  )}

  {related.length > 0 && (
    <>
      <h2 class="section-title">
        <span class="en-only">Governing building code</span>
        <span class="ar-only ar-text">كود البناء الحاكم</span>
      </h2>
      <p class="ybc-hint">
        <span class="en-only">Auto-linked from this character's materials, region type and risk level.</span>
        <span class="ar-only ar-text">مرتبطة تلقائياً بناءً على مواد هذا الطابع ونوع إقليمه ومستوى خطره.</span>
      </p>
      <ul class="ybc-links">
        {related.map((ch) => (
          <li>
            <a class="ybc-link" href={`/code/${ch.id}`}>
              <span class="ybc-code">{ch.data.code}</span>
              <span class="ybc-title">
                <span class="en-only">{ch.data.title}</span>
                <span class="ar-only ar-text">{ch.data.title_ar ?? ch.data.title}</span>
              </span>
              <svg class="ybc-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
            </a>
          </li>
        ))}
      </ul>
    </>
  )}

  <p class="cross-ref">
    <span class="en-only">Tagged: <span class="cr-em">{c.tag}</span> · <a href="/map">View on map</a></span>
    <span class="ar-only ar-text">الوسم: <span class="cr-em">{c.tag_ar ?? c.tag}</span> · <a href="/map">عرض على الخريطة</a></span>
  </p>

  <style>
    .lede { font-size: 1.12rem; line-height: 1.7; color: rgba(255,255,255,0.82); }
    .ch-diagram { margin: 0; }
    .ch-diagram img { width: 100%; border-radius: 10px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.02); }
    .ch-diagram figcaption { font-size: 0.78rem; color: rgba(255,255,255,0.45); margin-top: 0.5rem; text-align: center; }
    .ybc-hint { font-size: 0.82rem; color: rgba(255,255,255,0.45); margin: -0.5rem 0 1rem; }
    .ybc-links { list-style: none; display: grid; gap: 0.5rem; padding: 0; }
    .ybc-link {
      display: flex; align-items: center; gap: 0.85rem;
      background: rgba(74,222,128,0.06); border: 1px solid rgba(74,222,128,0.18);
      border-radius: 8px; padding: 0.7rem 1rem;
      transition: border-color 0.18s, background 0.18s, transform 0.18s;
    }
    .ybc-link:hover { border-color: rgba(74,222,128,0.5); background: rgba(74,222,128,0.1); transform: translateY(-1px); }
    .ybc-code { font-family: var(--f-mono, monospace); font-size: 0.72rem; color: #4ADE80; background: rgba(74,222,128,0.12); padding: 0.25rem 0.5rem; border-radius: 4px; white-space: nowrap; }
    .ybc-title { flex: 1; font-size: 0.95rem; color: #fff; }
    .ybc-arrow { color: rgba(255,255,255,0.35); flex-shrink: 0; }
    :where(html.lang-ar) .ybc-arrow { transform: scaleX(-1); }
    .section-title {
      font-family: var(--f-display, 'Cormorant Garamond', serif);
      font-weight: 500;
      font-size: 1.5rem;
      color: #fff;
      margin: 2.5rem 0 1rem;
    }
    .elements { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 0; }
    .element {
      font-size: 0.82rem;
      padding: 0.35rem 0.75rem;
      border: 1px solid rgba(251,191,36,0.3);
      border-radius: 999px;
      color: rgba(255,255,255,0.78);
    }
    .element.material { border-color: rgba(255,255,255,0.18); }
    .registers { display: grid; gap: 1rem; }
    .register {
      border-left: 2px solid var(--accent);
      padding: 0.25rem 0 0.25rem 1rem;
    }
    .register-key {
      font-size: 0.66rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .register-body { margin-top: 0.35rem; line-height: 1.6; }
    .cross-ref { margin-top: 2.5rem; font-size: 0.85rem; color: rgba(255,255,255,0.45); }
    .cross-ref .cr-em { color: rgba(255,255,255,0.7); }
    .cross-ref a { color: var(--accent); }
    :global(html.lang-ar) .register { border-left: none; border-right: 2px solid var(--accent); padding: 0.25rem 1rem 0.25rem 0; }
  </style>
</HeritageLayout>

---
import { getCollection } from 'astro:content';
import HeritageLayout from '../../layouts/HeritageLayout.astro';

export async function getStaticPaths() {
  const characters = await getCollection('characters');
  return characters.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const c = entry.data;

const registers = [
  { key: 'Traditional', body: c.traditional },
  { key: 'Transitional', body: c.transitional },
  { key: 'Contemporary', body: c.contemporary },
];
---
<HeritageLayout
  title={`${c.name} — Architectural Character · YAI`}
  description={c.description}
  eyebrow="Architectural Character"
  accent="#FBBF24"
  heading={c.name}
  headingAr={c.name_ar}
  meta={[
    { label: 'No.', value: c.num },
    { label: 'Governorate', value: c.governorate },
    { label: 'Material', value: c.material },
    { label: 'Period', value: c.period },
  ]}
>
  <p class="lede">{c.description}</p>

  <h2 class="section-title">Defining elements</h2>
  <ul class="elements">
    {c.elements.map((el) => <li class="element">{el}</li>)}
  </ul>

  <h2 class="section-title">Three registers</h2>
  <div class="registers">
    {registers.map((r) => (
      <div class="register">
        <span class="register-key">{r.key}</span>
        <p class="register-body">{r.body}</p>
      </div>
    ))}
  </div>

  <p class="cross-ref">
    Tagged: <span>{c.tag}</span> · <a href="/map">View on map</a>
  </p>

  <style>
    .lede { font-size: 1.12rem; line-height: 1.7; color: rgba(255,255,255,0.82); }
    .section-title {
      font-family: var(--f-display, 'Cormorant Garamond', serif);
      font-weight: 500;
      font-size: 1.5rem;
      color: #fff;
      margin: 2.5rem 0 1rem;
    }
    .elements { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 0; }
    .element {
      font-size: 0.82rem;
      padding: 0.35rem 0.75rem;
      border: 1px solid rgba(251,191,36,0.3);
      border-radius: 999px;
      color: rgba(255,255,255,0.78);
    }
    .registers { display: grid; gap: 1rem; }
    .register {
      border-left: 2px solid var(--accent);
      padding: 0.25rem 0 0.25rem 1rem;
    }
    .register-key {
      font-size: 0.66rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent);
    }
    .register-body { margin-top: 0.35rem; line-height: 1.6; }
    .cross-ref { margin-top: 2.5rem; font-size: 0.85rem; color: rgba(255,255,255,0.45); }
    .cross-ref span { color: rgba(255,255,255,0.7); }
    .cross-ref a { color: var(--accent); }
    :global(html.lang-ar) .register { border-left: none; border-right: 2px solid var(--accent); padding: 0.25rem 1rem 0.25rem 0; }
  </style>
</HeritageLayout>

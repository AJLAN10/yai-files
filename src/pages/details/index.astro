---
import { getCollection } from 'astro:content';
import HeritageLayout from '../../layouts/HeritageLayout.astro';
import SlidePanel from '../../components/SlidePanel.astro';
import { relatedYbc } from '../../lib/related';
import photoCredits from '../../data/photo-credits.json';
const sectorPhoto = (photoCredits as Record<string, any>)['sanaa-capital'];

/* Order by governorate catalogue number; Sheba (★) leads as the
   foundational character. */
const numOf = (c: { data: { num: string } }) =>
  c.data.num === '★' ? -1 : parseInt(c.data.num, 10);
const characters = (await getCollection('characters')).sort(
  (a, b) => numOf(a) - numOf(b),
);

const riskAr: Record<string, string> = {
  low: 'منخفض', moderate: 'متوسط', high: 'عالٍ', severe: 'شديد',
};

/* Slide-in panel records (same workspace pattern as the map). */
const ybcChapters = await getCollection('ybcChapters');
const panelRecords = characters.map((entry) => {
  const c = entry.data;
  return {
    id: entry.id,
    href: `/details/${entry.id}`,
    eyebrow: 'Architectural Character', eyebrow_ar: 'الطابع المعماري',
    title: c.name, title_ar: c.name_ar ?? c.name,
    sub: `${c.num} · ${c.governorate}`, sub_ar: `${c.num} · ${c.governorate}`,
    meta: [
      { k: 'Era', k_ar: 'الحقبة', v: c.era, v_ar: c.era_ar ?? c.era },
      { k: 'Risk', k_ar: 'الخطر', v: c.risk_level, v_ar: riskAr[c.risk_level] },
    ],
    sections: [
      { title: 'Materials', title_ar: 'المواد', type: 'tags', items: c.material_list.map((m, i) => ({ en: m, ar: c.material_list_ar?.[i] ?? m })) },
      { title: 'Defining elements', title_ar: 'العناصر المميزة', type: 'tags', items: c.elements.map((m, i) => ({ en: m, ar: c.elements_ar?.[i] ?? m })) },
      { title: 'Architectural character', title_ar: 'الطابع المعماري', type: 'text', text: c.description, text_ar: c.description_ar },
      { title: 'Governing building code', title_ar: 'كود البناء الحاكم', type: 'ybc', items: relatedYbc(c, ybcChapters).map((ch) => ({ code: ch.data.code, id: ch.id, title: ch.data.title, title_ar: ch.data.title_ar ?? ch.data.title })) },
    ],
    cta: 'Full character card →', cta_ar: 'بطاقة الطابع كاملة ←',
  };
});
---
<HeritageLayout
  title="Building Character — Architectural Characters · YAI"
  description="Character cards documenting Yemen's architectural characters — materials, eras, and the traditional / transitional / contemporary registers."
  eyebrow="Sector · In progress"
  eyebrowAr="قطاع · قيد الإنجاز"
  accent="#FBBF24"
  heading="Building Character for All Governorates"
  headingAr="الطابع المعماري لكل المحافظات"
  image={sectorPhoto?.src}
  imageCredit={sectorPhoto?.credit}
  imageLicense={sectorPhoto?.license}
  imageSource={sectorPhoto?.source}
  meta={[{ label: 'Character cards', label_ar: 'بطاقات الطوابع', value: String(characters.length) }]}
>
  <p class="lede en-only">
    The full Building Character sector is under construction. The documented character
    cards below are already available — each covers materials, era, defining
    elements, and the three design registers.
  </p>
  <p class="lede ar-only ar-text">
    قطاع التفاصيل قيد الإنشاء. بطاقات الطوابع الموثّقة أدناه متاحة بالفعل — تغطي كل
    منها المواد والحقبة والعناصر المميزة والسجلات التصميمية الثلاثة.
  </p>

  <ul class="cards grid-in">
    {characters.map((c) => (
      <li>
        <a href={`/details/${c.id}`} class="card" data-open-panel={c.id}>
          <span class="card-num">{c.data.num}</span>
          <span class="card-info">
            <span class="card-name">
              <span class="en-only">{c.data.name}</span>
              <span class="ar-only ar-text">{c.data.name_ar ?? c.data.name}</span>
            </span>
            <span class="card-tag">
              <span class="en-only">{c.data.tag}</span>
              <span class="ar-only ar-text">{c.data.tag_ar ?? c.data.tag}</span>
            </span>
          </span>
          <span class={`card-risk risk-${c.data.risk_level}`}>
            <span class="en-only">{c.data.risk_level}</span>
            <span class="ar-only ar-text">{riskAr[c.data.risk_level]}</span>
          </span>
        </a>
      </li>
    ))}
  </ul>

  <style>
    .lede { font-size: 1.05rem; line-height: 1.7; color: rgba(255,255,255,0.72); margin-bottom: 2rem; max-width: 54ch; }
    .cards { list-style: none; display: grid; gap: 0.5rem; padding: 0; }
    .card {
      display: flex; align-items: center; gap: 1rem;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
      border-radius: 8px; padding: 0.8rem 1rem; transition: border-color 0.15s, background 0.15s;
    }
    .card:hover { border-color: var(--accent); background: rgba(251,191,36,0.06); }
    .card-num {
      font-family: var(--f-display, 'Cormorant Garamond', serif);
      font-size: 1.3rem; color: var(--accent); min-width: 2ch; text-align: center;
    }
    .card-info { display: flex; flex-direction: column; gap: 0.15rem; flex: 1; }
    .card-name { font-size: 0.98rem; color: #fff; }
    .card-tag { font-size: 0.76rem; color: rgba(255,255,255,0.45); }
    .card-risk {
      font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase;
      padding: 0.2rem 0.5rem; border-radius: 999px; font-weight: 600;
    }
    .risk-low { background: rgba(74,222,128,0.15); color: #4ADE80; }
    .risk-moderate { background: rgba(251,191,36,0.15); color: #FBBF24; }
    .risk-high { background: rgba(251,146,60,0.18); color: #FB923C; }
    .risk-severe { background: rgba(248,113,113,0.18); color: #F87171; }
    :global(html.lang-ar) .card { flex-direction: row-reverse; }
  </style>

  <SlidePanel records={panelRecords} accent="#FBBF24" id="charPanel" />
</HeritageLayout>

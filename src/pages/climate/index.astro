---
import { getCollection } from 'astro:content';
import HeritageLayout from '../../layouts/HeritageLayout.astro';

const studies = (await getCollection('climateResilience')).sort(
  (a, b) => a.data.order - b.data.order,
);
const chapters = await getCollection('ybcChapters');

/* Inverted cross-link: build the resilience-tag → YBC-chapters index
   by querying each chapter's related_resilience_tags. The Climate
   sector consumes the tags; the chapters never point back here. */
const tagIndex = new Map<string, { code: string; title: string; id: string }[]>();
for (const ch of chapters) {
  for (const tag of ch.data.related_resilience_tags) {
    if (!tagIndex.has(tag)) tagIndex.set(tag, []);
    tagIndex.get(tag)!.push({ code: ch.data.code, title: ch.data.title, id: ch.id });
  }
}
const tagRows = [...tagIndex.entries()]
  .filter(([tag]) => tag !== 'governance')
  .sort((a, b) => a[0].localeCompare(b[0]));
---
<HeritageLayout
  title="Climate Resilience & Adaptive Reuse — YAI"
  description="Case studies of Yemen's heritage architecture adapting to flood, seismic, drought, and conflict risk — cross-referenced to the Yemen Building Code via resilience tags and mapped for field reference."
  eyebrow="New Sector"
  eyebrowAr="قطاع جديد"
  accent="#2DD4BF"
  heading="Climate Resilience & Adaptive Reuse"
  headingAr="المرونة المناخية وإعادة التأهيل"
  meta={[
    { label: 'Case studies', label_ar: 'دراسات الحالة', value: String(studies.length) },
    { label: 'Resilience themes', label_ar: 'محاور المرونة', value: String(tagRows.length) },
  ]}
>
  <p class="lede">
    How Yemen's built heritage absorbs climate and conflict risk — and how
    adaptive reuse keeps these structures in service. Each case study is
    matched to the Yemen Building Code chapters that govern its risk theme,
    and carries coordinates for plotting on the resilience map.
  </p>

  <h2 class="section-title"><span class="en-only">Case studies</span><span class="ar-only ar-text">دراسات الحالة</span></h2>
  <ul class="studies">
    {studies.map((s) => (
      <li class="study">
        <a href={`/climate/${s.id}`} class="study-link">
          <div class="study-badges">
            <span class={`risk risk-${s.data.risk_level}`}>{s.data.risk_level}</span>
            <span class="risk-type">{s.data.risk_type}</span>
          </div>
          <h3 class="study-title">{s.data.title}</h3>
          <p class="study-summary">{s.data.summary}</p>
          <span class="study-gov">{s.data.governorate}</span>
        </a>
      </li>
    ))}
  </ul>

  <h2 class="section-title"><span class="en-only">Resilience themes → YBC chapters</span><span class="ar-only ar-text">محاور المرونة ← فصول الكود</span></h2>
  <p class="hint">
    Built by querying each chapter's <code>related_resilience_tags</code> —
    the Climate sector reads the tags; chapters stay decoupled.
  </p>
  <ul class="tag-rows">
    {tagRows.map(([tag, chs]) => (
      <li class="tag-row">
        <span class="tag-name">{tag}</span>
        <span class="tag-chapters">
          {chs.map((ch) => (
            <a class="chip" href={`/code/${ch.id}`}>{ch.code} · {ch.title}</a>
          ))}
        </span>
      </li>
    ))}
  </ul>

  <style>
    .lede { font-size: 1.12rem; line-height: 1.7; color: rgba(255,255,255,0.82); margin-bottom: 1rem; }
    .section-title {
      font-family: var(--f-display, 'Cormorant Garamond', serif);
      font-weight: 500; font-size: 1.6rem; color: #fff; margin: 2.5rem 0 1rem;
    }
    .hint { font-size: 0.8rem; color: rgba(255,255,255,0.45); margin: -0.5rem 0 1rem; }
    .hint code {
      font-family: var(--f-mono, 'Fira Code', monospace);
      font-size: 0.85em; background: rgba(255,255,255,0.07); padding: 0.1em 0.35em; border-radius: 3px;
    }
    .studies { list-style: none; display: grid; gap: 1rem; padding: 0; }
    .study-link {
      display: block; background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08); border-radius: 10px;
      padding: 1.25rem 1.4rem; transition: border-color 0.15s, background 0.15s;
    }
    .study-link:hover { border-color: var(--accent); background: rgba(45,212,191,0.06); }
    .study-badges { display: flex; gap: 0.5rem; margin-bottom: 0.7rem; }
    .risk, .risk-type {
      font-size: 0.62rem; letter-spacing: 0.1em; text-transform: uppercase;
      padding: 0.2rem 0.55rem; border-radius: 999px;
    }
    .risk { font-weight: 600; }
    .risk-low { background: rgba(74,222,128,0.15); color: #4ADE80; }
    .risk-moderate { background: rgba(251,191,36,0.15); color: #FBBF24; }
    .risk-high { background: rgba(251,146,60,0.18); color: #FB923C; }
    .risk-severe { background: rgba(248,113,113,0.18); color: #F87171; }
    .risk-type { border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.6); }
    .study-title {
      font-family: var(--f-display, 'Cormorant Garamond', serif);
      font-weight: 500; font-size: 1.35rem; color: #fff; margin: 0 0 0.4rem;
    }
    .study-summary { font-size: 0.9rem; line-height: 1.6; color: rgba(255,255,255,0.6); margin: 0 0 0.7rem; }
    .study-gov { font-size: 0.72rem; letter-spacing: 0.05em; color: var(--accent); }
    .tag-rows { list-style: none; display: grid; gap: 0.6rem; padding: 0; }
    .tag-row {
      display: grid; grid-template-columns: 130px 1fr; gap: 1rem; align-items: start;
      padding: 0.7rem 0; border-bottom: 1px solid rgba(255,255,255,0.07);
    }
    .tag-name {
      font-size: 0.72rem; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--accent); padding-top: 0.3rem;
    }
    .tag-chapters { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .chip {
      font-size: 0.78rem; padding: 0.3rem 0.7rem; border-radius: 6px;
      border: 1px solid rgba(255,255,255,0.12); color: rgba(255,255,255,0.78);
    }
    .chip:hover { border-color: var(--accent); color: #fff; }
    @media (max-width: 560px) { .tag-row { grid-template-columns: 1fr; gap: 0.4rem; } }
  </style>
</HeritageLayout>

---
import { getCollection } from 'astro:content';
import HeritageLayout from '../../layouts/HeritageLayout.astro';

export async function getStaticPaths() {
  const kingdoms = await getCollection('kingdoms');
  return kingdoms.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const k = entry.data;
const eraLabel = k.special
  ? '★ Foundational kingdom'
  : k.era === 'pre' ? 'Pre-Islamic kingdom' : 'Islamic dynasty';
---
<HeritageLayout
  title={`${k.name} — Kingdom Archives · YAI`}
  description={k.description}
  eyebrow={`Kingdoms: Character & History · ${eraLabel}`}
  eyebrowAr={`الممالك: الطابع والتاريخ · ${k.special ? '★ المملكة المؤسِّسة' : k.era === 'pre' ? 'مملكة ما قبل الإسلام' : 'دولة إسلامية'}`}
  accent="#A78BFA"
  heading={k.name}
  headingAr={k.name_ar}
  meta={[
    { label: 'Period', label_ar: 'الفترة', value: k.dates_ar ?? k.dates },
    { label: 'Capital', label_ar: 'العاصمة', value: k.capital_ar ?? k.capital },
  ]}
>
  <p class="lede">
    <span class="en-only">{k.description}</span>
    <span class="ar-only ar-text">{k.description_ar ?? '(الترجمة العربية قيد الإعداد)'}</span>
  </p>

  <h2 class="section-title"><span class="en-only">Architectural legacy</span><span class="ar-only ar-text">الإرث المعماري</span></h2>
  <ul class="elements en-only">
    {k.architecture.map((a) => <li class="element">{a}</li>)}
  </ul>
  <ul class="elements ar-only">
    {(k.architecture_ar ?? k.architecture).map((a) => <li class="element ar-text">{a}</li>)}
  </ul>

  {k.badges.length > 0 && (
    <>
      <h2 class="section-title"><span class="en-only">Research status</span><span class="ar-only ar-text">حالة البحث</span></h2>
      <ul class="badges en-only">
        {k.badges.map((b) => <li class="badge">{b}</li>)}
      </ul>
      <ul class="badges ar-only">
        {(k.badges_ar ?? k.badges).map((b) => <li class="badge ar-text">{b}</li>)}
      </ul>
    </>
  )}

  <p class="cross-ref">
    <a href="/archives"><span class="en-only">← All 13 kingdoms</span><span class="ar-only ar-text">جميع الممالك الـ13 ←</span></a> · <a href="/map"><span class="en-only">View on map</span><span class="ar-only ar-text">عرض على الخريطة</span></a>
  </p>

  <style>
    .lede { font-size: 1.12rem; line-height: 1.75; color: rgba(255,255,255,0.82); }
    .section-title {
      font-family: var(--f-display, 'Cormorant Garamond', serif);
      font-weight: 500; font-size: 1.5rem; color: #fff; margin: 2.5rem 0 1rem;
    }
    .elements, .badges { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; padding: 0; }
    .element {
      font-size: 0.82rem; padding: 0.35rem 0.75rem; border-radius: 999px;
      border: 1px solid rgba(167,139,250,0.35); color: rgba(255,255,255,0.78);
    }
    .badge {
      font-size: 0.72rem; letter-spacing: 0.06em; padding: 0.3rem 0.7rem;
      border-radius: 999px; background: rgba(167,139,250,0.14); color: #C4B5FD;
    }
    .cross-ref { margin-top: 2.5rem; font-size: 0.85rem; color: rgba(255,255,255,0.45); }
    .cross-ref a { color: var(--accent); }
  </style>
</HeritageLayout>

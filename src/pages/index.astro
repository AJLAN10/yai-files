<!-- ═══════════════════════ SCRIPTS ═══════════════════════ -->
<script is:inline>
'use strict';

/* ─── Language toggle (EN ↔ AR) ────────────────────────────── */
const html = document.documentElement;
const langBtn = document.getElementById('langToggle');
let currentLang = 'en';

langBtn.addEventListener('click', () => {
  currentLang = currentLang === 'en' ? 'ar' : 'en';
  html.setAttribute('lang', currentLang);
  html.setAttribute('dir', currentLang === 'ar' ? 'rtl' : 'ltr');
  html.className = `lang-${currentLang}`;
  localStorage.setItem('yai-lang', currentLang);
  if (typeof plausible !== 'undefined') plausible('Language Toggle', { props: { language: currentLang } });
});

/* Restore language preference */
const savedLang = localStorage.getItem('yai-lang');
if (savedLang && savedLang !== 'en') langBtn.click();

/* ─── Mobile nav ───────────────────────────────────────────── */
const menuBtn = document.getElementById('menuBtn');
const navDrawer = document.getElementById('navDrawer');
menuBtn.addEventListener('click', () => {
  const isOpen = navDrawer.classList.toggle('open');
  menuBtn.setAttribute('aria-expanded', isOpen);
});

/* ─── Sector band expand/collapse ─────────────────────────── */
document.querySelectorAll('.sector-band').forEach(band => {
  const toggle = () => {
    const wasExpanded = band.classList.contains('expanded');
    document.querySelectorAll('.sector-band').forEach(b => { b.classList.remove('expanded'); b.setAttribute('aria-expanded', 'false'); });
    if (!wasExpanded) {
      band.classList.add('expanded');
      band.setAttribute('aria-expanded', 'true');
      const sector = band.dataset.s;
      if (typeof plausible !== 'undefined') plausible('Sector Expand', { props: { sector } });
    }
  };
  band.addEventListener('click', toggle);
  band.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(); } });
});

/* ─── PWA install prompt ───────────────────────────────────── */
let deferredPrompt = null;
const installBanner = document.getElementById('installBanner');
const installBtn = document.getElementById('installBtn');
const installClose = document.getElementById('installClose');
const navInstallBtn = document.getElementById('navInstallBtn');

window.addEventListener('beforeinstallprompt', e => {
  e.preventDefault();
  deferredPrompt = e;
  setTimeout(() => installBanner.classList.add('visible'), 4000);
  navInstallBtn.classList.add('visible');
});

const triggerInstall = async () => {
  if (!deferredPrompt) return;
  installBanner.classList.remove('visible');
  deferredPrompt.prompt();
  const { outcome } = await deferredPrompt.userChoice;
  if (typeof plausible !== 'undefined') plausible('PWA Install', { props: { outcome } });
  deferredPrompt = null;
};

installBtn.addEventListener('click', triggerInstall);
navInstallBtn.addEventListener('click', triggerInstall);
installClose.addEventListener('click', () => installBanner.classList.remove('visible'));

window.addEventListener('appinstalled', () => {
  navInstallBtn.classList.remove('visible');
  if (typeof plausible !== 'undefined') plausible('PWA Installed');
});

/* ─── Offline detection ────────────────────────────────────── */
const offlineBar = document.getElementById('offlineBar');
const updateOnlineStatus = () => {
  offlineBar.classList.toggle('visible', !navigator.onLine);
};
window.addEventListener('online', updateOnlineStatus);
window.addEventListener('offline', updateOnlineStatus);
updateOnlineStatus();

/* ─── Intro overlay cleanup ────────────────────────────────── */
const intro = document.querySelector('.intro-overlay');
if (intro) {
  intro.addEventListener('animationend', () => {
    intro.style.display = 'none';
    intro.setAttribute('aria-hidden', 'true');
  }, { once: true });
}

/* ─── Scroll reveal (IntersectionObserver) ─────────────────── */
const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      entry.target.classList.add('visible');
      revealObserver.unobserve(entry.target);
    }
  });
}, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });

document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

/* ─── Map city dot interaction ──────────────────────────────── */
document.querySelectorAll('.city-dot').forEach(dot => {
  dot.setAttribute('tabindex', '0');
  dot.setAttribute('role', 'button');
  const open = () => {
    const city = dot.dataset.city;
    if (city) window.location.href = `/characters/${city}`;
  };
  dot.addEventListener('click', open);
  dot.addEventListener('keydown', e => { if (e.key === 'Enter') open(); });
});

/* ─── Kingdom chips ─────────────────────────────────────────── */
document.querySelectorAll('.kingdom-chip').forEach(chip => {
  chip.addEventListener('click', () => {
    const name = chip.querySelector('.kc-name').textContent.trim().toLowerCase().replace(/[^a-z]/g,'');
    window.location.href = `/archives/${name}`;
  });
});

/* ─── Role-based onboarding (first visit) ───────────────────── */
if (!localStorage.getItem('yai-role')) {
  setTimeout(() => {
    const role = window.prompt(
      'Welcome to the Yemen Architecture Initiative.\n\nWho are you? (helps us personalise your experience)\n\n1. Architect / Engineer\n2. Student\n3. Government / Official\n4. General Public / Diaspora\n5. Researcher / Academic\n\nEnter a number (or press Cancel to skip):'
    );
    const roles = { '1':'architect', '2':'student', '3':'government', '4':'public', '5':'researcher' };
    const resolved = roles[role?.trim()] || 'public';
    localStorage.setItem('yai-role', resolved);
    if (typeof plausible !== 'undefined') plausible('Role Set', { props: { role: resolved } });
  }, 3000);
}
</script>


---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';
---
<BaseLayout
  title="Yemen Architecture Initiative — مبادرة العمارة اليمنية"
  description="The global platform for Yemen's architectural heritage. 23 architectural characters, Yemen Building Code, 13 kingdom archives, and education resources — in Arabic and English. مبادرة العمارة اليمنية: 23 طابعاً معمارياً، كود البناء اليمني، وأرشيف 13 مملكة."
>
<Fragment slot="head">
<meta name="keywords" content="Yemen architecture, Yemeni heritage, سنعاء, Sana'a, Shibam, Zabid, Hadramawt, Yemen Building Code, YBC, architectural heritage, قاموس العمارة اليمنية, مبادرة العمارة, Kingdom of Sheba, مملكة سبأ, UNESCO Yemen">

<!-- Canonical & hreflang -->
<link rel="canonical" href="https://yai.org/">
<link rel="alternate" hreflang="en" href="https://yai.org/en/">
<link rel="alternate" hreflang="ar" href="https://yai.org/ar/">
<link rel="alternate" hreflang="x-default" href="https://yai.org/">

<!-- Open Graph — controls Facebook, LinkedIn, WhatsApp previews -->
<meta property="og:type" content="website">
<meta property="og:site_name" content="Yemen Architecture Initiative">
<meta property="og:title" content="Yemen Architecture Initiative — مبادرة العمارة اليمنية">
<meta property="og:description" content="The global platform for Yemen's built heritage. 23 architectural characters. Yemen Building Code. 13 kingdom archives spanning 3,000 years.">
<meta property="og:url" content="https://yai.org/">
<meta property="og:image" content="https://yai.org/og-image.jpg">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:alt" content="Yemen Architecture Initiative — Old City of Sana'a tower houses">
<meta property="og:locale" content="en_US">
<meta property="og:locale:alternate" content="ar_YE">

<!-- Twitter / X Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:site" content="@YemenArchInit">
<meta name="twitter:creator" content="@YemenArchInit">
<meta name="twitter:title" content="Yemen Architecture Initiative">
<meta name="twitter:description" content="The global platform for Yemen's built heritage — 23 architectural characters, building code, kingdom archives.">
<meta name="twitter:image" content="https://yai.org/og-image.jpg">
<meta name="twitter:image:alt" content="Yemen Architecture Initiative">

<!-- JSON-LD Structured Data — tells Google what this platform is -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://yai.org/#website",
      "url": "https://yai.org/",
      "name": "Yemen Architecture Initiative",
      "alternateName": "مبادرة العمارة اليمنية",
      "description": "The global platform for Yemen's architectural heritage, building code, and cultural archives.",
      "inLanguage": ["en", "ar"],
      "potentialAction": {
        "@type": "SearchAction",
        "target": { "@type": "EntryPoint", "urlTemplate": "https://yai.org/search?q={search_term_string}" },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "CulturalOrganization",
      "@id": "https://yai.org/#organization",
      "name": "Yemen Architecture Initiative",
      "alternateName": "YAI",
      "url": "https://yai.org",
      "logo": "https://yai.org/icons/icon-512.png",
      "description": "A global initiative documenting Yemen's architectural heritage across 22 governorates and 13 historical kingdoms, producing the Yemen Building Code for heritage structures.",
      "sameAs": [
        "https://twitter.com/YemenArchInit",
        "https://www.linkedin.com/company/yai"
      ],
      "knowsAbout": ["Yemen architecture", "Islamic architecture", "Heritage conservation", "Kingdom of Sheba", "Building codes"]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What is the Yemen Architecture Initiative?",
          "acceptedAnswer": { "@type": "Answer", "text": "A global platform documenting Yemen's architectural heritage across 22 governorates, producing the Yemen Building Code for heritage structures, and maintaining archives of 13 historical kingdoms spanning 3,000 years." }
        },
        {
          "@type": "Question",
          "name": "What is the Yemen Building Code (YBC)?",
          "acceptedAnswer": { "@type": "Answer", "text": "The YBC Heritage Module is a technical code covering construction standards for mudbrick, fired brick, coral stone, and rammed earth — the four primary materials of Yemen's vernacular architecture — plus seismic, flood, and post-conflict reconstruction protocols." }
        }
      ]
    }
  ]
}
</script>

<!-- Plausible analytics — privacy-first, no cookies -->
<link rel="preconnect" href="https://plausible.io">
<script defer data-domain="yai.org" src="https://plausible.io/js/script.tagged-events.js"></script>
</Fragment>

<!-- ═══════════════════════ BROWSER INTRO ═══════════════════════ -->
<div class="intro-overlay" role="presentation" aria-hidden="true">
  <div class="intro-logotype">
    <div class="intro-en">Yemen Architecture Initiative</div>
    <div class="intro-line"></div>
    <div class="intro-ar">مبادرة العمارة اليمنية</div>
    <div class="intro-sub">Heritage · Code · Education · Archives</div>
  </div>
</div>

<!-- ═══════════════════════ OFFLINE BAR ═══════════════════════ -->
<div class="offline-bar" id="offlineBar" role="alert" aria-live="polite">
  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;vertical-align:-2px;margin-right:6px"><path d="M1 1l22 22M16.72 11.06A10.94 10.94 0 0 1 19 12.55M5 12.55a10.94 10.94 0 0 1 5.17-2.39M10.71 5.05A16 16 0 0 1 22.56 9M1.42 9a15.91 15.91 0 0 1 4.7-2.88M8.53 16.11a6 6 0 0 1 6.95 0M12 20h.01"/></svg>
  You are offline — content cached for offline use · أنت غير متصل بالإنترنت
</div>

<!-- ═══════════════════════ INSTALL BANNER ═══════════════════════ -->
<div class="install-banner" id="installBanner" role="dialog" aria-label="Install Yemen Architecture Initiative">
  <div class="install-icon">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#C4A77D" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>
  </div>
  <div class="install-text">
    <div class="install-title en-only">Install YAI</div>
    <div class="install-title ar-only ar-text">تثبيت التطبيق</div>
    <div class="install-sub en-only">Offline access to all 23 characters & YBC</div>
    <div class="install-sub ar-only ar-text">وصول دون اتصال إلى جميع الطوابع الـ23 وكود البناء</div>
  </div>
  <button class="install-btn" id="installBtn" aria-label="Install application"><span class="en-only">Install</span><span class="ar-only ar-text">تثبيت</span></button>
  <button class="install-close" id="installClose" aria-label="Dismiss install banner">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6 6 18M6 6l12 12"/></svg>
  </button>
</div>

<!-- ═══════════════════════ NAVIGATION ═══════════════════════ -->
<nav class="nav" role="navigation" aria-label="Main navigation">
  <a href="/" class="nav-logo" aria-label="Yemen Architecture Initiative — Home">
    <div class="nav-logo-mark" aria-hidden="true">
      <svg viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg"><path d="M9 1 L17 5 L17 13 L9 17 L1 13 L1 5 Z" fill="none" stroke="#0F172A" stroke-width="1.5"/><path d="M9 1 L9 17 M1 5 L17 13 M17 5 L1 13" stroke="#0F172A" stroke-width="0.8" opacity="0.5"/></svg>
    </div>
    <span class="nav-logo-name en-only">Yemen <span>Architecture</span></span>
    <span class="nav-logo-name ar-only" style="font-family:var(--f-ar-body);direction:rtl">مبادرة <span>العمارة</span></span>
  </a>

  <div class="nav-links" role="menubar">
    <a href="/map"      class="nav-link" role="menuitem" data-sector="map" aria-label="Interactive map"><span class="en-only">Map</span><span class="ar-only ar-text">الخريطة</span></a>
    <a href="/students" class="nav-link" role="menuitem" data-sector="students"><span class="en-only">Students</span><span class="ar-only ar-text">الطلاب</span></a>
    <a href="/code"     class="nav-link" role="menuitem" data-sector="code"><span class="en-only">Code</span><span class="ar-only ar-text">الكود</span></a>
    <a href="/details"  class="nav-link" role="menuitem" data-sector="details"><span class="en-only">Details</span><span class="ar-only ar-text">التفاصيل</span></a>
    <a href="/general"  class="nav-link" role="menuitem" data-sector="general"><span class="en-only">General</span><span class="ar-only ar-text">عام</span></a>
    <a href="/archives" class="nav-link" role="menuitem" data-sector="archives"><span class="en-only">Archives</span><span class="ar-only ar-text">الأرشيف</span></a>
  </div>

  <div class="nav-actions">
    <button class="nav-lang" id="langToggle" aria-label="Toggle language — تبديل اللغة">
      <span class="en-only">العربية</span>
      <span class="ar-only">English</span>
    </button>
    <button class="nav-install-btn" id="navInstallBtn" aria-label="Install app">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:5px"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      <span class="en-only">Install</span>
      <span class="ar-only ar-text">تثبيت</span>
    </button>
    <button class="nav-menu-btn" id="menuBtn" aria-expanded="false" aria-controls="navDrawer" aria-label="Toggle navigation">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
    </button>
  </div>
</nav>

<!-- Mobile nav drawer -->
<div class="nav-drawer" id="navDrawer" role="menu" aria-label="Mobile navigation">
  <a href="/map" class="nav-drawer-link" role="menuitem"><span class="nav-drawer-dot" style="background:#C4A77D"></span><span class="en-only">Interactive Map</span><span class="ar-only ar-text">الخريطة التفاعلية</span></a>
  <a href="/students" class="nav-drawer-link" role="menuitem"><span class="nav-drawer-dot" style="background:var(--c-students)"></span><span class="en-only">Students</span><span class="ar-only ar-text">الطلاب</span></a>
  <a href="/code" class="nav-drawer-link" role="menuitem"><span class="nav-drawer-dot" style="background:var(--c-code)"></span><span class="en-only">Code (YBC)</span><span class="ar-only ar-text">الكود (YBC)</span></a>
  <a href="/details" class="nav-drawer-link" role="menuitem"><span class="nav-drawer-dot" style="background:var(--c-details)"></span><span class="en-only">Details</span><span class="ar-only ar-text">التفاصيل</span></a>
  <a href="/general" class="nav-drawer-link" role="menuitem"><span class="nav-drawer-dot" style="background:var(--c-general)"></span><span class="en-only">General</span><span class="ar-only ar-text">عام</span></a>
  <a href="/archives" class="nav-drawer-link" role="menuitem"><span class="nav-drawer-dot" style="background:var(--c-archives)"></span><span class="en-only">Archives</span><span class="ar-only ar-text">الأرشيف</span></a>
</div>

<main id="main-content">

<!-- ═══════════════════════ HERO ═══════════════════════ -->
<section class="hero" aria-label="Yemen Architecture Initiative — Hero">
  <div class="hero-main">
    <div class="hero-en">
      <p class="hero-eyebrow en-only">Global Heritage Platform — Est. 2026</p>
      <p class="hero-eyebrow ar-only ar-text">منصة التراث العالمية — تأسست 2026</p>
      <h1 class="hero-headline">
        <span class="w1 en-only">Yemen</span>
        <span class="w2 en-only">Architecture</span>
        <span class="w3 en-only">Initiative</span>
        <span class="ar-only ar-text">مبادرة العمارة اليمنية</span>
      </h1>
      <p class="hero-tagline en-only">
        A global platform for Yemen's built heritage — 23 architectural characters, the Yemen Building Code, 13 kingdom archives, and educational resources in Arabic and English.
      </p>
      <p class="hero-tagline ar-only ar-text">
        منصة عالمية للتراث المعماري اليمني — 23 طابعاً معمارياً، كود البناء اليمني، أرشيف 13 مملكة، وموارد تعليمية بالعربية والإنجليزية.
      </p>
      <div class="hero-ctas">
        <a href="/map" class="btn-primary" aria-label="Explore the interactive architecture map">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6l6-3 6 3 6-3v15l-6 3-6-3-6 3V6z"/><path d="M9 3v15M15 6v15"/></svg>
          <span class="en-only">Explore the Map</span>
          <span class="ar-only ar-text">استكشف الخريطة</span>
        </a>
        <a href="/archives" class="btn-outline" aria-label="Enter the Kingdom Archives">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          <span class="en-only">Kingdom Archives</span>
          <span class="ar-only ar-text">أرشيف الممالك</span>
        </a>
      </div>
    </div>
    <div class="hero-ar" aria-hidden="true">
      <div class="hero-ar-text">مبادرة<br>العمارة<br>اليمنية</div>
    </div>
  </div>

  <div class="hero-stats" role="list" aria-label="Platform statistics">
    <div class="hero-stat" role="listitem">
      <span class="stat-num">23<span class="stat-accent">+</span></span>
      <span class="stat-label en-only">Architectural Characters</span>
      <span class="stat-label ar-only ar-text">طابعاً معمارياً</span>
    </div>
    <div class="hero-stat" role="listitem">
      <span class="stat-num">13</span>
      <span class="stat-label en-only">Kingdom Archives</span>
      <span class="stat-label ar-only ar-text">أرشيف مملكة</span>
    </div>
    <div class="hero-stat" role="listitem">
      <span class="stat-num">51</span>
      <span class="stat-label en-only">Scholarly Sources — 5 Languages</span>
      <span class="stat-label ar-only ar-text">مصدراً علمياً — 5 لغات</span>
    </div>
    <div class="hero-stat" role="listitem">
      <span class="stat-num">3<span class="stat-accent">K</span></span>
      <span class="stat-label en-only">Years of History Documented</span>
      <span class="stat-label ar-only ar-text">سنة من التاريخ الموثق</span>
    </div>
  </div>
</section>

<!-- ═══════════════════════ SECTORS ═══════════════════════ -->
<section class="sectors-section reveal" aria-label="Five platform sectors">
  <div class="section-header">
    <div>
      <p class="section-eyebrow en-only">The platform</p>
      <p class="section-eyebrow ar-only ar-text">المنصة</p>
      <h2 class="section-title en-only">Five sectors — one heritage</h2>
      <h2 class="section-title ar-only ar-text">خمسة قطاعات — تراث واحد</h2>
    </div>
  </div>

  <div class="sector-bands" role="list">

    <div class="sector-band" data-s="students" role="listitem" tabindex="0" aria-expanded="false" aria-label="Students sector">
      <div class="sector-accent-bar" aria-hidden="true"></div>
      <div class="sector-icon-wrap" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="#0369A1" stroke-width="1.8"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
      </div>
      <div class="sector-info">
        <span class="sector-name en-only">Students</span>
        <span class="sector-name ar-only ar-text">الطلاب</span>
        <span class="sector-desc en-only">Learning hub, research library, classroom toolkits, annual competition</span>
        <span class="sector-desc ar-only ar-text">مركز تعليمي، مكتبة بحثية، أدوات صفية، مسابقة سنوية</span>
      </div>
      <span class="sector-count en-only">6 resources</span>
      <span class="sector-count ar-only ar-text">6 موارد</span>
      <div class="sector-arrow" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </div>
      <div class="sector-expand" aria-hidden="true">
        <p class="sector-expand-text en-only">Architecture students at every level — from school through university — find structured courses, the full 51-source research library across 5 languages, measured drawing exercises, and an annual global design competition using Yemen's 23 architectural characters as studio brief.</p>
        <p class="sector-expand-text ar-only ar-text">يجد طلاب العمارة في كل المراحل — من المدرسة إلى الجامعة — مقررات منظمة، ومكتبة بحثية كاملة من 51 مصدراً عبر 5 لغات، وتمارين رفع معماري، ومسابقة تصميم عالمية سنوية باستخدام الطوابع المعمارية اليمنية الـ23 كموجز استوديو.</p>
        <a href="/students" class="sector-cta"><span class="en-only">Enter sector</span><span class="ar-only ar-text">دخول القطاع</span> <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      </div>
    </div>

    <div class="sector-band" data-s="code" role="listitem" tabindex="0" aria-expanded="false" aria-label="Yemen Building Code sector">
      <div class="sector-accent-bar" aria-hidden="true"></div>
      <div class="sector-icon-wrap" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="#15803D" stroke-width="1.8"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      </div>
      <div class="sector-info">
        <span class="sector-name en-only">Code (YBC)</span>
        <span class="sector-name ar-only ar-text">الكود (YBC)</span>
        <span class="sector-desc en-only">Yemen Building Code — 8 heritage chapters covering all construction traditions</span>
        <span class="sector-desc ar-only ar-text">كود البناء اليمني — 8 فصول تراثية تغطي جميع تقاليد البناء</span>
      </div>
      <span class="sector-count en-only">8 chapters</span>
      <span class="sector-count ar-only ar-text">8 فصول</span>
      <div class="sector-arrow" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </div>
      <div class="sector-expand" aria-hidden="true">
        <p class="sector-expand-text en-only">The Yemen Building Code Heritage Module — material standards for libn (mudbrick), fired brick, coral stone, and rammed earth; seismic and flood resilience codes; post-conflict reconstruction authenticity standards. Downloadable PDF for offline fieldwork. Aligned with UNESCO and ALIPH protocols.</p>
        <p class="sector-expand-text ar-only ar-text">وحدة كود البناء اليمني التراثية — معايير مواد اللبن (الطوب الطيني)، الطوب المحروق، الحجر المرجاني، والطين المدكوك؛ أكواد مقاومة الزلازل والفيضانات؛ معايير الأصالة في إعادة الإعمار بعد النزاع. ملف PDF قابل للتنزيل للعمل الميداني دون اتصال. متوافق مع بروتوكولات اليونسكو وأليف.</p>
        <a href="/code" class="sector-cta"><span class="en-only">Enter sector</span><span class="ar-only ar-text">دخول القطاع</span> <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      </div>
    </div>

    <div class="sector-band" data-s="details" role="listitem" tabindex="0" aria-expanded="false" aria-label="Details sector">
      <div class="sector-accent-bar" aria-hidden="true"></div>
      <div class="sector-icon-wrap" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="#B45309" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
      </div>
      <div class="sector-info">
        <span class="sector-name en-only">Details</span>
        <span class="sector-name ar-only ar-text">التفاصيل</span>
        <span class="sector-desc en-only">23 character cards, material library, element catalogue, 3D documentation</span>
        <span class="sector-desc ar-only ar-text">23 بطاقة طابع، مكتبة مواد، فهرس عناصر، توثيق ثلاثي الأبعاد</span>
      </div>
      <span class="sector-count en-only">23 characters</span>
      <span class="sector-count ar-only ar-text">23 طابعاً</span>
      <div class="sector-arrow" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </div>
      <div class="sector-expand" aria-hidden="true">
        <p class="sector-expand-text en-only">The professional documentation core — every character card contains full history, climate-response analysis, primary material specifications, typology drawings, and three design typologies (traditional, transitional, contemporary). Supported by the element catalogue — qamaria, mafraj, rawshan, birka — and a 3D documentation archive in partnership with Iconem and CEFAS.</p>
        <p class="sector-expand-text ar-only ar-text">جوهر التوثيق الاحترافي — تحتوي كل بطاقة طابع على التاريخ الكامل، وتحليل الاستجابة المناخية، ومواصفات المواد الأساسية، ورسومات النمطية، وثلاث نمطيات تصميم (تقليدية، انتقالية، معاصرة). مدعومة بفهرس العناصر — القمرية، المفرج، الروشان، البركة — وأرشيف توثيق ثلاثي الأبعاد بالشراكة مع Iconem وCEFAS.</p>
        <a href="/details" class="sector-cta"><span class="en-only">Enter sector</span><span class="ar-only ar-text">دخول القطاع</span> <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
      </div>
    </div>


---
interface Props {
  title: string;
  description: string;
  /* 'light' = parchment lobby pages; 'dark' = archival record pages. */
  theme?: 'light' | 'dark';
}

const { title, description, theme = 'light' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ar" dir="rtl" class={`lang-ar theme-${theme}`}>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<meta http-equiv="X-UA-Compatible" content="IE=edge">

<title>{title}</title>
<meta name="description" content={description}>
<meta name="author" content="Yemen Architecture Initiative">
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">

<!-- Content Security Policy (in-document fallback; frame-ancestors is set
     via real HTTP headers in public/_headers since <meta> ignores it).
     'unsafe-inline' is required for the site's is:inline island scripts. -->
<meta http-equiv="Content-Security-Policy" content="default-src 'self'; base-uri 'self'; object-src 'none'; img-src 'self' data:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; connect-src 'self'; form-action 'self'">

<!-- Copyright / rights metadata (deterrence without disabling browser UX) -->
<meta name="copyright" content="© 2026 Yemen Architecture Initiative (YAI). All rights reserved.">
<meta name="rights" content="Content © 2026 Yemen Architecture Initiative. Cite as: Yemen Architecture Initiative (YAI), yai.org. Third-party imagery retains its original CC licence as credited.">
<link rel="license" href="/privacy">
<meta name="theme-color" content="#0F172A" media="(prefers-color-scheme: dark)">
<meta name="theme-color" content="#0F172A" media="(prefers-color-scheme: light)">
<meta name="color-scheme" content="light">
<meta name="mobile-web-app-capable" content="yes">
<meta name="application-name" content="YAI">

<!-- Apple PWA meta -->
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="YAI">

<!-- PWA manifest -->
<link rel="manifest" href="/manifest.json">
<link rel="icon" type="image/png" href="/icons/icon-192.png" sizes="192x192">
<link rel="icon" type="image/png" href="/icons/icon-512.png" sizes="512x512">
<link rel="apple-touch-icon" href="/icons/icon-192.png">

<!-- Preconnect for performance -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

<!-- Fonts from design system MASTER.md -->
<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Cairo:wght@300;400;500;600;700&family=Zain:wght@300;400;700;800&family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=Fira+Code:wght@400;500&family=Noto+Naskh+Arabic:wght@400;500;600;700&family=Noto+Sans+Arabic:wght@300;400;500;700&display=swap">
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Cairo:wght@300;400;500;600;700&family=Zain:wght@300;400;700;800&family=Cormorant+Garamond:wght@400;500;600&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&family=Fira+Code:wght@400;500&family=Noto+Naskh+Arabic:wght@400;500;600;700&family=Noto+Sans+Arabic:wght@300;400;500;700&display=swap">

<slot name="head" />
</head>
<body>
<slot />

<!-- Subtle copyright notice on image right-click. Deliberately does NOT
     call preventDefault: the native context menu (and 'Save image',
     accessibility, citation) stays fully available — we only inform. -->
<div id="yai-copyright-toast" role="status" aria-live="polite"></div>
<style>
  #yai-copyright-toast {
    position: fixed; inset-block-end: 1.1rem; inset-inline: 0;
    margin-inline: auto; width: max-content; max-width: 90vw;
    padding: 0.6rem 1.05rem; border-radius: 9px;
    background: rgba(15, 23, 42, 0.96); color: #fff;
    font-size: 0.8rem; line-height: 1.4; text-align: center;
    border: 1px solid rgba(255, 255, 255, 0.16);
    box-shadow: 0 12px 34px rgba(0, 0, 0, 0.45);
    opacity: 0; transform: translateY(10px);
    transition: opacity 0.22s ease, transform 0.22s ease;
    pointer-events: none; z-index: 200;
  }
  #yai-copyright-toast.show { opacity: 1; transform: none; }
  @media (prefers-reduced-motion: reduce) { #yai-copyright-toast { transition: opacity 0.22s ease; transform: none; } }
</style>
<script is:inline>
(function () {
  var ar = document.documentElement.classList.contains('lang-ar');
  var toast = document.getElementById('yai-copyright-toast');
  if (!toast) return;
  var timer;
  document.addEventListener('contextmenu', function (e) {
    var img = e.target && e.target.closest ? e.target.closest('img') : null;
    if (!img) return;
    /* No preventDefault — keep the browser's menu; just surface a credit. */
    toast.textContent = ar
      ? '© 2026 مبادرة العمارة اليمنية — يُرجى الإسناد: yai.org'
      : '© 2026 Yemen Architecture Initiative — please cite as: yai.org';
    toast.classList.add('show');
    clearTimeout(timer);
    timer = setTimeout(function () { toast.classList.remove('show'); }, 3400);
  });
})();
</script>

<script>
/* Offline-first was dropped by project decision (2026-06). Clean up any
   previously installed service worker + caches so stale pages stop
   being served to returning visitors. Remove this after a few deploys. */
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.getRegistrations().then(regs => regs.forEach(r => r.unregister()));
  if ('caches' in window) caches.keys().then(keys => keys.forEach(k => caches.delete(k)));
}
</script>
</body>
</html>
